# Development gateway configuration only. Do not store credentials here.
NATS_URL=nats://localhost:4222
GATEWAY_ADDR=:8443
GATEWAY_CERT_PATH=platform/infrastructure/certs
DASHBOARD_ADDR=127.0.0.1:8080
DASHBOARD_ALLOWED_ORIGIN=https://localhost:5173
GATEWAY_STATE_PATH=platform/services/gateway/data
FILE_OPERATOR_ID=internal-website
ACTIVITY_OFFLINE_AFTER=30s
ACTIVITY_SWEEP_INTERVAL=5s

# The deployed build and operating environment must match the selected and
# independently approved cryptographic provider evidence.
CRYPTO_PROVIDER=go-cryptographic-module
CRYPTO_ALLOWED_MODULE_VERSIONS=v1.0.0-c2097c7c
CRYPTO_PROVIDER_CERTIFICATE=CMVP-5247
CRYPTO_SECURITY_POLICY=Go Cryptographic Module v1.0.0 Security Policy
CRYPTO_ALLOWED_ENVIRONMENTS=linux/amd64

# Keep command-signing material separate from TLS identity files.
COMMAND_SIGNING_KEY_PATH=platform/services/gateway/secrets/command-signing.key
COMMAND_PUBLIC_KEY_PATH=platform/services/gateway/state/command-signing.pub
